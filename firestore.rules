rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============== القراءات العامة (بدون تسجيل دخول) ==============
    // التطبيق يقرأ فقط
    match /categories/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /subcategories/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /products/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /banners/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /offers/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /articles/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /settings/{doc} { allow read: if true; allow write: if request.auth != null; }

    // ============== الطلبات ==============
    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============== المستخدم (بياناته الشخصية) ==============
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // المفضلة الفرعية للمستخدم
      match /favorites/{favId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // العناوين الفرعية
      match /addresses/{addrId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ============== الأدمن فقط ==============
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
